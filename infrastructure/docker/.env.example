# ==========================================================================
# Cozy Canvas - Environment Variables Reference
# ==========================================================================
# This file serves as a template for your local configuration.
# Instructions:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in the actual values for your environment.
# 3. NEVER commit your real .env file to version control.
# ==========================================================================

# --- [ Backend Core ] ---
# The port where the Go API server will run.
# Default: 8080 (Common for local development)
PORT=8080

# --- [ Database ] ---
# Full PostgreSQL connection URL.
# Format: postgres://[user]:[password]@[host]:[port]/[dbname]?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cozy_canvas?sslmode=disable

# Individual DB components (used by docker-compose)
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=cozy_canvas
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=disable

# --- [ Security ] ---
# A strong, random string used to sign JWT tokens for authentication.
# For local dev, a simple string works, but use a complex one in production.
JWT_SECRET=cozy-canvas-super-secret-development-key-2024

# --- [ Frontend & CORS ] ---
# Comma-separated list of origins allowed to make requests to this API.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- [ Object Storage - MinIO ] ---
# S3-compatible storage configuration.
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=cozyadmin
MINIO_SECRET_KEY=cozysecret
MINIO_BUCKET=cozy-assets

# MinIO Root credentials (for container initialization)
MINIO_ROOT_USER=cozyadmin
MINIO_ROOT_PASSWORD=cozysecret
