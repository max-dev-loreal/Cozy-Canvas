# ==========================================================================
# Cozy Canvas Configuration Template (.env)
# ==========================================================================

# Database Configurations
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=cozy_canvas
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cozy_canvas?sslmode=disable

# MinIO Object Storage Configurations
MINIO_ROOT_USER=cozyadmin
MINIO_ROOT_PASSWORD=cozysecret
MINIO_ENDPOINT=localhost:9000
MINIO_BUCKET_NAME=cozy-canvas-assets
