# ==============================================================================
# Cozy Canvas - Environment Variables
# Copy this file to .env and replace the placeholder values.
# Do not commit .env files containing secrets.
# ==============================================================================

# API Configuration
PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Authentication
# Generate a secure secret:
# openssl rand -base64 32
JWT_SECRET=your_jwt_secret

# PostgreSQL
DB_USER=canvas_admin
DB_PASSWORD=secure_db_password_123
DB_NAME=cozy_canvas_db
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=disable

# Connection string used by the application
DATABASE_URL=postgres://canvas_admin:secure_db_password_123@localhost:5432/cozy_canvas_db?sslmode=disable

# S3 / MinIO Storage
MINIO_ROOT_USER=minio_root_admin
MINIO_ROOT_PASSWORD=minio_root_password_999
MINIO_ENDPOINT=localhost:9000
MINIO_BUCKET_NAME=cozy-canvas-attachments
MINIO_USE_SSL=false