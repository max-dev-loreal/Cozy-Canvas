# ==========================================================================
# Cozy Canvas - Global Gitignore Configurations
# ==========================================================================

# OS Specific
.DS_Store
Thumbs.db
desktop.ini

# IDEs and Editors
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Frontend (Node.js & Vite)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
website/dist/
website/package-lock.json

# Backend (Go)
backend/bin/
backend/*.exe
backend/*.test
backend/*.out
backend/backend
# Ignore compiled executables
*.exe
*.exe~
*.dll
*.so
*.dylib

# Environment Variables & Secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
infrastructure/docker/.env

# Local database volumes / object storage temp data (if mapped locally)
postgres-data/
minio-data/
